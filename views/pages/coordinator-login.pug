doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title Coordinator Login
    link(rel="stylesheet" href="/styles/css/Coordinator-login-Page.css")
  body
    main.wrap
      section.card(aria-label="Coordinator Login")
        h1 Community Kit Share
        p Admin / Coordinator login
        if error
          p.small.err= error
        form(method="post" action="/coordinator/login")
          label(for="email") Email
          input#email(type="email" name="email" required autofocus)

          label(for="password") Password
          input#password(type="password" name="password" required)

          button(type="submit") Log in
          p.small Demo coordinator: karim@example.com
          p.small Default password: password123
          p.small
            a(href="/member/login") Member login →